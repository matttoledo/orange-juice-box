{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "asDropdown": false,
      "icon": "external link",
      "includeVars": false,
      "keepTime": false,
      "tags": [],
      "targetBlank": true,
      "title": "Netdata (realtime)",
      "tooltip": "Auto-discovering realtime observability",
      "type": "link",
      "url": "http://192.168.15.2:19999"
    }
  ],
  "panels": [
    {
      "type": "row",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 100,
      "title": "🎯 NPU (Rockchip RK3588 NPU)",
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "NPU Core Load (%)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 1},
      "id": 1,
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "rknpu_core_load_percent",
          "legendFormat": "core {{core}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {"lineWidth": 2, "fillOpacity": 20, "gradientMode": "opacity"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 60},
              {"color": "red", "value": 85}
            ]
          }
        }
      },
      "options": {"tooltip": {"mode": "multi"}, "legend": {"showLegend": true, "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"]}}
    },
    {
      "type": "gauge",
      "title": "NPU Temp",
      "gridPos": {"h": 8, "w": 6, "x": 12, "y": 1},
      "id": 2,
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "rk3588_thermal_zone_celsius{name=\"npu-thermal\"}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "min": 20,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 65},
              {"color": "orange", "value": 80},
              {"color": "red", "value": 90}
            ]
          }
        }
      },
      "options": {"orientation": "auto", "showThresholdLabels": false, "showThresholdMarkers": true}
    },
    {
      "type": "stat",
      "title": "Collector Freshness",
      "gridPos": {"h": 8, "w": 6, "x": 18, "y": 1},
      "id": 3,
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "time() - rknpu_collector_last_success_timestamp_seconds",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 30},
              {"color": "red", "value": 60}
            ]
          }
        }
      },
      "options": {"colorMode": "background", "graphMode": "area", "textMode": "auto"}
    },
    {
      "type": "row",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 9},
      "id": 101,
      "title": "🌡️ Thermal Zones (RK3588 — 7 zones)",
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "All Thermal Zones",
      "gridPos": {"h": 9, "w": 18, "x": 0, "y": 10},
      "id": 4,
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "rk3588_thermal_zone_celsius",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "min": 20,
          "custom": {"lineWidth": 2, "fillOpacity": 5, "gradientMode": "opacity"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 70},
              {"color": "red", "value": 85}
            ]
          }
        }
      },
      "options": {"tooltip": {"mode": "multi", "sort": "desc"}, "legend": {"showLegend": true, "displayMode": "table", "placement": "right", "calcs": ["current", "max"]}}
    },
    {
      "type": "bargauge",
      "title": "Current Temps",
      "gridPos": {"h": 9, "w": 6, "x": 18, "y": 10},
      "id": 5,
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "rk3588_thermal_zone_celsius",
          "legendFormat": "{{name}}",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "min": 20,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 65},
              {"color": "orange", "value": 80},
              {"color": "red", "value": 90}
            ]
          }
        }
      },
      "options": {"orientation": "horizontal", "displayMode": "gradient", "showUnfilled": true}
    },
    {
      "type": "row",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 19},
      "id": 102,
      "title": "💾 Host — CPU / RAM / Disk",
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "CPU by Mode (%)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 20},
      "id": 6,
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "100 - (avg by (mode) (rate(node_cpu_seconds_total{mode=\"idle\"}[1m])) * 100)",
          "legendFormat": "used",
          "refId": "A"
        },
        {
          "expr": "avg by (mode) (rate(node_cpu_seconds_total{mode=~\"user|system|iowait\"}[1m])) * 100",
          "legendFormat": "{{mode}}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {"lineWidth": 2, "fillOpacity": 10, "stacking": {"mode": "none"}}
        }
      },
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"]}}
    },
    {
      "type": "timeseries",
      "title": "Memory Usage",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 20},
      "id": 7,
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes",
          "legendFormat": "used",
          "refId": "A"
        },
        {
          "expr": "node_memory_MemAvailable_bytes",
          "legendFormat": "available",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {"lineWidth": 2, "fillOpacity": 20, "stacking": {"mode": "normal"}}
        }
      },
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"]}}
    },
    {
      "type": "row",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 28},
      "id": 103,
      "title": "🌐 Network — Interfaces",
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Network Rx/Tx (bytes/sec)",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 29},
      "id": 8,
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "rate(node_network_receive_bytes_total{device!~\"lo|docker.*|veth.*|br-.*\"}[1m])",
          "legendFormat": "rx {{device}}",
          "refId": "A"
        },
        {
          "expr": "-rate(node_network_transmit_bytes_total{device!~\"lo|docker.*|veth.*|br-.*\"}[1m])",
          "legendFormat": "tx {{device}}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {"lineWidth": 2, "fillOpacity": 10}
        }
      },
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"]}}
    }
  ],
  "preload": false,
  "refresh": "15s",
  "schemaVersion": 41,
  "tags": ["orangepi", "npu", "rk3588"],
  "templating": {"list": []},
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "Orange Pi 5 — NPU + Thermal + Host",
  "uid": "orangepi-npu",
  "version": 1,
  "weekStart": ""
}
